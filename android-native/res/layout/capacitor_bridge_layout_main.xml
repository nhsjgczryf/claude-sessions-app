<?xml version="1.0" encoding="utf-8"?>
<!--
   Overrides Capacitor 7's bundled capacitor_bridge_layout_main.xml
   (BridgeActivity does setContentView(R.layout.capacitor_bridge_layout_main)).
   The bundled version is just a CoordinatorLayout wrapping a
   com.getcapacitor.CapacitorWebView@+id/webview. We replace it with a
   vertical LinearLayout: the same CapacitorWebView (weight 1) on top,
   and a NATIVE compose bar (EditText + ↵ Send) docked below.

   Why native: Android WebView has an unfixable Chromium bug where
   editing CJK / non-Latin text in the middle of a web <input>/
   <textarea> snaps the caret to the end. A native EditText uses
   Android's own text editing and doesn't have it. ComposeInputPlugin
   shows/hides this bar and bridges its text to the WebView.

   With windowSoftInputMode=adjustResize the soft keyboard pushes the
   layout up, so the bar sits above the keyboard — no pixel math. Bar
   starts GONE; the plugin shows it when a terminal tab is active.

   IMPORTANT: the WebView MUST be com.getcapacitor.CapacitorWebView
   (Capacitor's Bridge casts findViewById(R.id.webview) to it) and the
   file MUST be named capacitor_bridge_layout_main.xml — the old
   bridge_layout_main.xml name is from pre-7 Capacitor and is ignored.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1e1e2e">

    <com.getcapacitor.CapacitorWebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/compose_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="#252536"
        android:padding="6dp"
        android:gravity="bottom">

        <EditText
            android:id="@+id/compose_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1e1e2e"
            android:textColor="#cdd6f4"
            android:textColorHint="#6c7086"
            android:hint="Tap to type · 中文/英文 · Send →"
            android:inputType="textMultiLine|textNoSuggestions"
            android:maxLines="6"
            android:minHeight="44dp"
            android:padding="10dp"
            android:textSize="15sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:imeOptions="flagNoExtractUi" />

        <Button
            android:id="@+id/compose_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:minWidth="56dp"
            android:text="↵"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1e1e2e"
            android:background="#89b4fa" />
    </LinearLayout>
</LinearLayout>
