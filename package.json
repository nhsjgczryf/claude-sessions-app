{
  "name": "claude-sessions",
  "version": "2.0.0",
  "description": "Manage multiple Claude Code terminal sessions (local + SSH) with xterm.js — Electron desktop, self-hosted web server, and a native Android APK that does its own SSH (via sshj).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "web": "node web/server.js",
    "android:init": "node scripts/android-init.js",
    "android:build": "node scripts/android-init.js && cd android && ./gradlew assembleDebug"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.1.0",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "katex": "^0.16.0",
    "marked": "^14.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/clipboard": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "electron": "^41.2.1"
  }
}
